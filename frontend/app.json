{
  "expo": {
    "name": "DCF Valuation",
    "slug": "dcf-valuation-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.akulahluwalia.dcfvaluation"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "package": "com.akulahluwalia.dcfvaluation"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router"],
    "scheme": "dcfvaluation",
    "experiments": {
      "baseUrl": "/dcf-valuation-app"
    }
  }
}
